<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Us Time — לוח המשחק לזוגות</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --pink:#D4537E;--pink-d:#993556;--pink-l:#FBEAF0;--pink-b:#F4C0D1;
  --blue:#378ADD;--blue-l:#E6F1FB;
  --red:#E24B4A;--red-l:#FCEBEB;
  --amber:#EF9F27;--teal:#1D9E75;--purple:#7F77DD;--gold:#FAC775;
  --text:#1a1a1a;--text2:#666;--text3:#999;
  --bg:#fafaf8;--surf:#fff;--surf2:#f4f2ee;
  --border:rgba(0,0,0,.09);--border2:rgba(0,0,0,.18);
  --rad:10px;--rad-lg:16px;--rad-xl:22px;
  --shadow:0 4px 20px rgba(0,0,0,.1);
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue',Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center;overflow-x:hidden;}
.page{width:100%;max-width:480px;padding:20px 18px 80px;}
.sc{display:none;}.sc.on{display:block;}
#s-penalty.on{display:flex;}

/* ---- SETUP ---- */
.brand{text-align:center;padding:1.5rem 0 1.5rem;}
.logo-tag{display:inline-block;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--pink);background:var(--pink-l);padding:4px 12px;border-radius:99px;margin-bottom:12px;}
.brand h1{font-size:28px;font-weight:800;letter-spacing:-.8px;}
.brand p{font-size:14px;color:var(--text2);margin-top:6px;line-height:1.5;}
.sec-lbl{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text3);margin-bottom:10px;margin-top:1.25rem;}
.inp-row{display:flex;gap:10px;}
.ing{flex:1;}
.ing label{display:block;font-size:12px;color:var(--text2);margin-bottom:6px;}
.ing input{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:var(--rad);background:var(--surf);color:var(--text);font-size:15px;outline:none;transition:border-color .15s;}
.ing input:focus{border-color:var(--pink);}
.mode-wrap{display:flex;background:var(--surf2);border-radius:var(--rad-lg);padding:4px;gap:4px;}
.mode-btn{flex:1;padding:10px;border:none;border-radius:var(--rad);background:transparent;color:var(--text2);font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;}
.mode-btn.active{background:var(--surf);color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,.1);}
.legend{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;}
.leg{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);}
.leg-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;}
.rules-box{background:var(--surf);border:1.5px solid var(--border);border-radius:var(--rad-lg);padding:1rem 1.25rem;}
.rules-box h3{font-size:13px;font-weight:700;margin-bottom:10px;}
.rule{display:flex;gap:10px;font-size:12px;color:var(--text2);margin-bottom:7px;line-height:1.45;}
.rule-ico{font-size:14px;flex-shrink:0;}
.start-btn{width:100%;padding:17px;margin-top:1.5rem;border-radius:var(--rad-lg);background:var(--pink);color:#fff;border:none;font-size:17px;font-weight:800;cursor:pointer;box-shadow:0 6px 18px rgba(212,83,126,.35);transition:all .15s;letter-spacing:-.3px;}
.start-btn:hover{background:var(--pink-d);transform:translateY(-1px);}

/* ---- SCOREBOARD ---- */
.sboard{display:flex;gap:8px;margin-bottom:10px;}
.ps-wrap{flex:1;position:relative;}
.ps{border-radius:var(--rad-lg);padding:11px 8px;text-align:center;background:var(--surf2);border:2px solid transparent;transition:all .25s;}
.ps.t1{border-color:var(--pink);background:var(--pink-l);}
.ps.t2{border-color:var(--blue);background:var(--blue-l);}
.ps-name{font-size:12px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:1px;}
.ps-n{font-size:26px;font-weight:800;color:var(--text);line-height:1;}
.ps-meta{font-size:11px;color:var(--text3);margin-top:2px;min-height:14px;}
.score-anim{position:absolute;top:8px;left:50%;transform:translateX(-50%);font-size:18px;font-weight:800;color:var(--pink);pointer-events:none;animation:floatUp .85s ease-out forwards;z-index:10;}
@keyframes floatUp{from{opacity:1;transform:translateX(-50%) translateY(0);}to{opacity:0;transform:translateX(-50%) translateY(-44px);}}

/* ---- GAME ---- */
.turn-line{text-align:center;font-size:14px;color:var(--text2);margin-bottom:8px;}
.turn-line b{color:var(--text);font-weight:700;}
.round-info{text-align:center;font-size:12px;color:var(--text3);margin-bottom:8px;}
.rtrack{display:flex;justify-content:center;gap:4px;margin-bottom:12px;flex-wrap:wrap;}
.rdo{width:9px;height:9px;border-radius:50%;background:var(--surf2);border:1.5px solid var(--border);flex-shrink:0;transition:all .3s;}
.rdo.p1{background:var(--pink);border-color:var(--pink);}
.rdo.p2{background:var(--blue);border-color:var(--blue);}
.rdo.cur{outline:2.5px solid var(--border2);outline-offset:1px;}

/* ---- WHEEL ---- */
.warea{display:flex;flex-direction:column;align-items:center;margin-bottom:10px;}
.ptr{font-size:20px;line-height:1;margin-bottom:-5px;z-index:1;}
#wc{border-radius:50%;box-shadow:0 6px 28px rgba(0,0,0,.15);}
.spin-btn{margin-top:14px;padding:14px 48px;background:var(--pink);color:#fff;border:none;border-radius:var(--rad-lg);font-size:15px;font-weight:800;cursor:pointer;box-shadow:0 5px 16px rgba(212,83,126,.35);transition:all .15s;}
.spin-btn:hover{background:var(--pink-d);}
.spin-btn:disabled{background:var(--surf2);color:var(--text3);box-shadow:none;cursor:default;}
.landed-badge{text-align:center;font-size:14px;font-weight:600;color:var(--text2);min-height:22px;margin-top:8px;}

/* ---- CARD ---- */
.crd{background:var(--surf);border-radius:var(--rad-xl);border:2px solid var(--border);box-shadow:var(--shadow);padding:2rem 1.5rem;text-align:center;min-height:240px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;margin-bottom:14px;transition:border-color .3s;animation:popIn .3s ease-out;}
@keyframes popIn{from{transform:scale(.92);opacity:0;}to{transform:scale(1);opacity:1;}}
.cbadge{font-size:12px;font-weight:700;padding:5px 14px;border-radius:99px;letter-spacing:.3px;}
.spicy-pill{display:inline-block;font-size:10px;background:#FF4500;color:#fff;padding:1px 7px;border-radius:99px;margin-left:4px;font-weight:700;}
.cicon{font-size:30px;line-height:1;}
.ctext{font-size:18px;font-weight:700;color:var(--text);line-height:1.5;}
.csub{font-size:13px;color:var(--text2);font-style:italic;}
.wopts{display:flex;flex-direction:column;gap:8px;width:100%;}
.wopt{padding:12px 16px;border-radius:var(--rad);border:1.5px solid var(--border);background:var(--surf2);font-size:14px;color:var(--text);text-align:center;}
.vs{font-size:13px;font-weight:700;color:var(--text3);}
.hs-timer{position:relative;width:84px;height:84px;}
.hs-timer svg{position:absolute;top:0;left:0;}
.hs-tnum{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:28px;font-weight:800;color:var(--text);font-variant-numeric:tabular-nums;}
.hs-tsub{text-align:center;font-size:11px;color:var(--text3);margin-top:4px;}
.arow{display:flex;gap:10px;}
.done-btn{flex:2;padding:15px;background:var(--pink);color:#fff;border:none;border-radius:var(--rad-lg);font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 12px rgba(212,83,126,.3);transition:background .15s;}
.done-btn:hover{background:var(--pink-d);}
.skip-b{flex:1;padding:15px;background:var(--surf2);color:var(--text2);border:1.5px solid var(--border);border-radius:var(--rad-lg);font-size:14px;cursor:pointer;transition:all .15s;}
.skip-b:hover{background:var(--surf);}

/* ---- PENALTY ---- */
#s-penalty{
  min-height:100vh;flex-direction:column;align-items:center;justify-content:center;
  padding:2rem 1.5rem;text-align:center;position:relative;overflow:hidden;
  background:linear-gradient(160deg,#1a0505 0%,#2d0808 60%,#1f0505 100%);
}
.penalty-glow{position:absolute;width:320px;height:320px;border-radius:50%;background:rgba(226,75,74,.14);filter:blur(70px);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;}
.pen-icon{font-size:78px;margin-bottom:12px;display:block;animation:shakeX .55s ease-in-out;}
@keyframes shakeX{0%,100%{transform:translateX(0)}15%{transform:translateX(-10px)}45%{transform:translateX(10px)}75%{transform:translateX(-6px)}90%{transform:translateX(6px)}}
.pen-label{display:inline-block;font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:#E24B4A;background:rgba(226,75,74,.18);padding:4px 14px;border-radius:99px;margin-bottom:14px;}
.pen-title{font-size:24px;font-weight:800;color:#fff;margin-bottom:18px;}
.pen-text{font-size:19px;font-weight:600;color:#fff;line-height:1.65;background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.13);border-radius:var(--rad-xl);padding:1.5rem 1.25rem;margin-bottom:20px;width:100%;max-width:420px;transition:opacity .2s;}
.pen-btns{display:flex;flex-direction:column;gap:10px;width:100%;max-width:420px;}
.pen-accept{padding:16px;background:var(--pink);color:#fff;border:none;border-radius:var(--rad-lg);font-size:16px;font-weight:800;cursor:pointer;box-shadow:0 6px 20px rgba(212,83,126,.4);transition:all .15s;}
.pen-accept:hover{background:var(--pink-d);}
.pen-reroll{padding:12px;background:rgba(255,255,255,.09);color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.16);border-radius:var(--rad-lg);font-size:14px;cursor:pointer;transition:all .15s;}
.pen-reroll:hover{background:rgba(255,255,255,.15);}

/* ---- RESULT ---- */
.res{text-align:center;padding:1.5rem 0;}
.res-hero{width:110px;height:110px;border-radius:50%;background:var(--pink-l);display:flex;align-items:center;justify-content:center;font-size:52px;margin:0 auto 20px;box-shadow:0 8px 24px rgba(212,83,126,.2);}
.res-t{font-size:30px;font-weight:800;color:var(--text);margin-bottom:8px;letter-spacing:-.5px;}
.res-s{font-size:15px;color:var(--text2);margin-bottom:2rem;line-height:1.5;}
.fscores{display:flex;gap:10px;margin-bottom:2rem;}
.fsc{flex:1;padding:1.5rem 1rem;background:var(--surf2);border-radius:var(--rad-lg);border:2px solid transparent;text-align:center;transition:all .3s;}
.fsc.win{border-color:var(--pink);background:var(--pink-l);}
.fsc-n{font-size:13px;color:var(--text2);margin-bottom:4px;}
.fsc-p{font-size:42px;font-weight:800;color:var(--text);line-height:1;}
.fsc-m{font-size:12px;color:var(--text3);margin-top:5px;}
.again-btn{padding:16px 48px;background:var(--pink);color:#fff;border:none;border-radius:var(--rad-lg);font-size:16px;font-weight:800;cursor:pointer;box-shadow:0 6px 18px rgba(212,83,126,.35);}
.again-btn:hover{background:var(--pink-d);}

/* ---- TOAST ---- */
#toast-wrap{position:fixed;top:22px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;align-items:center;gap:8px;pointer-events:none;}
.toast{background:var(--text);color:#fff;padding:11px 20px;border-radius:99px;font-size:14px;font-weight:600;white-space:nowrap;transform:translateY(-20px);opacity:0;transition:all .3s ease;box-shadow:0 4px 16px rgba(0,0,0,.25);}
.toast.show{transform:translateY(0);opacity:1;}
.toast.streak{background:var(--amber);color:var(--text);}
.toast.warn{background:var(--red);}
.toast.bonus{background:var(--teal);}

/* ---- CONFETTI ---- */
#confetti-c{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;display:none;}

.footer{text-align:center;font-size:12px;color:var(--text3);margin-top:1.5rem;}
</style>
</head>
<body>

<canvas id="confetti-c"></canvas>
<div id="toast-wrap"></div>

<div class="page">

<!-- ====== SETUP ====== -->
<div id="s-setup" class="sc on">
  <div class="brand">
    <div class="logo-tag">Us Time</div>
    <h1>לוח המשחק לזוגות 🎡</h1>
    <p>סובבו את הגלגל, קבלו קלף, ותחרו<br>6 סוגי קלפים · 12 סיבובים · עונשים!</p>
  </div>

  <div class="sec-lbl">שמות השחקנים</div>
  <div class="inp-row">
    <div class="ing"><label>שחקן 1</label><input id="p1n" type="text" placeholder="השם שלך..." maxlength="10"></div>
    <div class="ing"><label>שחקן 2</label><input id="p2n" type="text" placeholder="השם שלהם..." maxlength="10"></div>
  </div>

  <div class="sec-lbl">מצב משחק</div>
  <div class="mode-wrap">
    <button id="mode-normal" class="mode-btn active" onclick="setMode('normal')">💌 רגיל</button>
    <button id="mode-spicy" class="mode-btn" onclick="setMode('spicy')">🌶️ מסעיר</button>
  </div>

  <div class="sec-lbl">סוגי קלפים</div>
  <div class="legend">
    <div class="leg"><div class="leg-dot" style="background:#D4537E"></div>💬 שאלה (2נק')</div>
    <div class="leg"><div class="leg-dot" style="background:#EF9F27"></div>🎯 אתגר (2נק')</div>
    <div class="leg"><div class="leg-dot" style="background:#7F77DD"></div>⚡ מעדיף? (2נק')</div>
    <div class="leg"><div class="leg-dot" style="background:#E24B4A"></div>🔥 מושב חם (3נק')</div>
    <div class="leg"><div class="leg-dot" style="background:#1D9E75"></div>🧩 זוגון (3נק')</div>
    <div class="leg"><div class="leg-dot" style="background:#FAC775"></div>⭐ בונוס (4נק')</div>
  </div>

  <div class="rules-box" style="margin-top:1.25rem">
    <h3>איך משחקים?</h3>
    <div class="rule"><span class="rule-ico">🎡</span><span>כל תור — השחקן הנוכחי מסובב את הגלגל</span></div>
    <div class="rule"><span class="rule-ico">🃏</span><span>הגלגל בוחר סוג קלף אקראי — קראו בקול ועשו!</span></div>
    <div class="rule"><span class="rule-ico">✅</span><span>השלמתם? קבלו נקודות. דלגתם? קבלו <b>עונש!</b> 🐔</span></div>
    <div class="rule"><span class="rule-ico">🔥</span><span>3 השלמות ברצף = +1 נקודת בונוס אוטומטית!</span></div>
    <div class="rule"><span class="rule-ico">🏆</span><span>אחרי 12 סיבובים — הניקוד קובע מי ניצח!</span></div>
  </div>

  <button class="start-btn" onclick="startGame()">התחילו לשחק! →</button>
  <div class="footer">Us Time · כל הזכויות שמורות ©</div>
</div>

<!-- ====== GAME ====== -->
<div id="s-game" class="sc">
  <div class="sboard">
    <div class="ps-wrap" id="pw1"><div class="ps" id="ps1"><div class="ps-name" id="ps1n">שחקן 1</div><div class="ps-n" id="ps1p">0</div><div class="ps-meta" id="ps1m"></div></div></div>
    <div class="ps-wrap" id="pw2"><div class="ps" id="ps2"><div class="ps-name" id="ps2n">שחקן 2</div><div class="ps-n" id="ps2p">0</div><div class="ps-meta" id="ps2m"></div></div></div>
  </div>
  <div class="turn-line">תור של: <b id="tname">-</b></div>
  <div class="round-info" id="rinfo">סיבוב 1 מתוך 12</div>
  <div class="rtrack" id="rtrack"></div>
  <div class="warea">
    <div class="ptr">▼</div>
    <canvas id="wc" width="260" height="260"></canvas>
    <button class="spin-btn" id="spin-btn" onclick="doSpin()">סובבו!</button>
    <div class="landed-badge" id="landed"></div>
  </div>
</div>

<!-- ====== CARD ====== -->
<div id="s-card" class="sc">
  <div class="sboard">
    <div class="ps-wrap" id="cpw1"><div class="ps" id="cp1"><div class="ps-name" id="cp1n">שחקן 1</div><div class="ps-n" id="cp1p">0</div><div class="ps-meta" id="cp1m"></div></div></div>
    <div class="ps-wrap" id="cpw2"><div class="ps" id="cp2"><div class="ps-name" id="cp2n">שחקן 2</div><div class="ps-n" id="cp2p">0</div><div class="ps-meta" id="cp2m"></div></div></div>
  </div>
  <div class="crd" id="crd"></div>
  <div class="arow">
    <button class="skip-b" onclick="doSkip()">דלגתי 🐔</button>
    <button class="done-btn" id="doneb">השלמתי ✓</button>
  </div>
</div>

<!-- ====== PENALTY ====== -->
<div id="s-penalty" class="sc">
  <div class="penalty-glow"></div>
  <span id="pen-icon" class="pen-icon">🐔</span>
  <div class="pen-label">⚠️ עונש!</div>
  <div class="pen-title">דלגת? אז קבל/י!</div>
  <div class="pen-text" id="pen-text"></div>
  <div class="pen-btns">
    <button class="pen-reroll" onclick="rerollPenalty()">🎲 עונש אחר</button>
    <button class="pen-accept" onclick="acceptPenalty()">קיבלתי על עצמי ✓</button>
  </div>
</div>

<!-- ====== RESULT ====== -->
<div id="s-result" class="sc">
  <div class="res">
    <div class="res-hero" id="ric">🏆</div>
    <div class="res-t" id="rt">כל הכבוד!</div>
    <div class="res-s" id="rs">המשחק הסתיים</div>
    <div class="fscores">
      <div class="fsc" id="fs1"><div class="fsc-n" id="fs1n">שחקן 1</div><div class="fsc-p" id="fs1p">0</div><div class="fsc-m" id="fs1m"></div></div>
      <div class="fsc" id="fs2"><div class="fsc-n" id="fs2n">שחקן 2</div><div class="fsc-p" id="fs2p">0</div><div class="fsc-m" id="fs2m"></div></div>
    </div>
    <button class="again-btn" onclick="goSetup()">משחק חדש 🔄</button>
    <div class="footer">Us Time · שיהיה לכם מהנה! ❤️</div>
  </div>
</div>

</div>

<script>
/* ===== DATA ===== */
const SEGS=[
  {name:'שאלה',  icon:'💬',bg:'#D4537E',fg:'#fff',   type:'q',pts:2},
  {name:'אתגר!', icon:'🎯',bg:'#EF9F27',fg:'#412402',type:'d',pts:2},
  {name:'מעדיף?',icon:'⚡',bg:'#7F77DD',fg:'#fff',   type:'w',pts:2},
  {name:'מושב חם',icon:'🔥',bg:'#E24B4A',fg:'#fff',  type:'h',pts:3},
  {name:'זוגון', icon:'🧩',bg:'#1D9E75',fg:'#fff',   type:'z',pts:3},
  {name:'בונוס', icon:'⭐',bg:'#FAC775',fg:'#412402',type:'b',pts:4},
];

const CARDS={
  q:[
    {t:'מה הדבר שהפרטנר שלך עושה שגורם לך להרגיש הכי אהוב/ה?'},
    {t:'מה הרגע שבו ידעת שהפרטנר שלך מיוחד/ת לך?'},
    {t:'מה הפחד הגדול ביותר שלך — ואיך הפרטנר עוזר לך איתו?'},
    {t:'מה הדבר שהייתי רוצה שנעשה יותר ביחד?',s:'שיחה פתוחה — ענו בכנות'},
    {t:'אם הייתם שולחים מכתב לעצמכם לפני 10 שנים, מה הייתם כותבים?'},
    {t:'מה הגרסה הטובה ביותר של עצמך שאתה שואף להיות?'},
    {t:'מה הדבר שהכי קשה לך לבקש מהפרטנר?',s:'ענו בכנות'},
    {t:'מה הרגע בחיים שלך שהכי שינה אותך?'},
    {t:'מה הדבר שאתה נותן לאחרים שקשה לך לתת לעצמך?'},
    {t:'מה הדבר שהייתי רוצה שתדע עלי אבל קשה לי לומר?'},
    {t:'מה המשפט שמישהו אמר לך שנשאר אצלך עד היום?'},
    {t:'מה הדבר שהכי אהבת לעשות כילד/ה שכבר לא עושה?'},
  ],
