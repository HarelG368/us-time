/* ===== UTILS ===== */
function showSc(id){document.querySelectorAll('.sc').forEach(s=>s.classList.remove('on'));document.getElementById(id).classList.add('on');}
function setMode(m){gameMode=m;document.getElementById('mode-normal').classList.toggle('active',m==='normal');document.getElementById('mode-spicy').classList.toggle('active',m==='spicy');}

function getCard(type){
  const pool=[...(CARDS[type]||[])];
  if(gameMode==='spicy'&&SPICY[type])pool.push(...SPICY[type]);
  if(!usedCards[type])usedCards[type]=new Set();
  if(usedCards[type].size>=pool.length)usedCards[type].clear();
  let idx,tries=0;
  do{idx=Math.floor(Math.random()*pool.length);tries++;}
  while(usedCards[type].has(idx)&&tries<30);
  usedCards[type].add(idx);
  return pool[idx];
}

/* ===== TOAST ===== */
function showToast(msg,type=''){
  const w=document.getElementById('toast-wrap');
  const t=document.createElement('div');
  t.className='toast'+(type?' '+type:'');
  t.textContent=msg;
  w.appendChild(t);
  requestAnimationFrame(()=>requestAnimationFrame(()=>t.classList.add('show')));
  setTimeout(()=>{t.classList.remove('show');setTimeout(()=>t.remove(),300);},2800);
}

