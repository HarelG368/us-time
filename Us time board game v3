function buildTrack(){
  const t=document.getElementById('rtrack');t.innerHTML='';
  for(let i=0;i<12;i++){const d=document.createElement('div');d.className='rdo'+(i===0?' cur':'');d.id='rd'+i;t.appendChild(d);}
}

function updateTrack(){
  for(let i=0;i<12;i++){
    const d=document.getElementById('rd'+i);if(!d)continue;
    d.className='rdo';
    if(i<round)d.classList.add(i%2===0?'p1':'p2');
    else if(i===round)d.classList.add('cur');
  }
}

/* ===== WHEEL ===== */
function drawWheel(rotation){
  const canvas=document.getElementById('wc');if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height,cx=W/2,cy=H/2,r=cx-6;
  ctx.clearRect(0,0,W,H);
  const arc=2*Math.PI/SEGS.length;
  SEGS.forEach((seg,i)=>{
    const a=rotation+i*arc-Math.PI/2;
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,a,a+arc);ctx.closePath();
    ctx.fillStyle=seg.bg;ctx.fill();ctx.strokeStyle='#fff';ctx.lineWidth=3;ctx.stroke();
    ctx.save();ctx.translate(cx,cy);ctx.rotate(a+arc/2);ctx.textAlign='center';
    ctx.font='16px sans-serif';ctx.fillStyle=seg.fg;ctx.fillText(seg.icon,r*.6,2);
    ctx.font='600 10px sans-serif';ctx.fillText(seg.name,r*.6,16);
    ctx.restore();
  });
  ctx.beginPath();ctx.arc(cx,cy,24,0,2*Math.PI);ctx.fillStyle='#fff';ctx.fill();ctx.strokeStyle='#ddd';ctx.lineWidth=2;ctx.stroke();
  ctx.font='16px sans-serif';ctx.textAlign='center';ctx.fillText('♥',cx,cy+6);
}

function doSpin(){
  if(spinning)return;spinning=true;
  document.getElementById('spin-btn').disabled=true;
  document.getElementById('landed').textContent='';
  const winner=Math.floor(Math.random()*SEGS.length);
  const arc=2*Math.PI/SEGS.length;
  const tMod=((-(winner*arc+arc/2))%(2*Math.PI)+2*Math.PI)%(2*Math.PI);
  const cMod=((rot%(2*Math.PI))+2*Math.PI)%(2*Math.PI);
  let delta=tMod-cMod;if(delta<=.01)delta+=2*Math.PI;
  const total=(6+Math.random()*4)*2*Math.PI+delta;
  const s0=rot,s1=rot+total,st=performance.now(),dur=4000;
  function frame(now){
    const t=Math.min((now-st)/dur,1);
    const e=1-Math.pow(1-t,4);
    rot=s0+e*(s1-s0);drawWheel(rot);
    if(t<1){requestAnimationFrame(frame);}
    else{
      rot=s1;spinning=false;
      const seg=SEGS[winner];
      document.getElementById('landed').textContent=seg.icon+' קיבלת: '+seg.name+'!';
      if(round===11)showToast('⚡ סיבוב אחרון!','warn');
      setTimeout(()=>showCard(winner),700);
    }
  }
  requestAnimationFrame(frame);
}

