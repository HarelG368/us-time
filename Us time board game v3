  document.getElementById('fs1n').textContent=p[0];document.getElementById('fs1p').textContent=pts[0];
  document.getElementById('fs2n').textContent=p[1];document.getElementById('fs2p').textContent=pts[1];
  document.getElementById('fs1m').textContent=skips[0]>0?'🐔 דילג/ה '+skips[0]+' פעמים':'✅ אף דילוג!';
  document.getElementById('fs2m').textContent=skips[1]>0?'🐔 דילג/ה '+skips[1]+' פעמים':'✅ אף דילוג!';
  document.getElementById('fs1').classList.toggle('win',w===0);
  document.getElementById('fs2').classList.toggle('win',w===1);
  if(w===-1){document.getElementById('ric').textContent='🤝';document.getElementById('rt').textContent='תיקו מושלם!';document.getElementById('rs').textContent='כשהאהבה שווה — כולם מנצחים!';}
  else{document.getElementById('ric').textContent='🏆';document.getElementById('rt').textContent=p[w]+' ניצח/ה!';document.getElementById('rs').textContent='עם '+pts[w]+' נקודות — כל הכבוד!';}
  showSc('s-result');
  setTimeout(startConfetti,400);
}

/* ===== CONFETTI ===== */
function startConfetti(){
  const canvas=document.getElementById('confetti-c');
  canvas.style.display='block';
  canvas.width=window.innerWidth;canvas.height=window.innerHeight;
  const ctx=canvas.getContext('2d');
  const colors=['#D4537E','#EF9F27','#7F77DD','#1D9E75','#FAC775','#378ADD','#E24B4A'];
  const ps=Array.from({length:90},()=>({
    x:Math.random()*canvas.width,y:Math.random()*canvas.height-canvas.height,
    w:7+Math.random()*9,h:4+Math.random()*5,
    vx:(Math.random()-.5)*2.5,vy:2.5+Math.random()*3,
    angle:Math.random()*Math.PI*2,va:(Math.random()-.5)*.1,
    color:colors[Math.floor(Math.random()*colors.length)],alpha:1,
  }));
  let f=0;
  function anim(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    ps.forEach(q=>{
      q.x+=q.vx;q.y+=q.vy;q.angle+=q.va;
      if(q.y>canvas.height){q.y=-10;q.x=Math.random()*canvas.width;}
      if(f>160)q.alpha=Math.max(0,q.alpha-.008);
      ctx.save();ctx.translate(q.x,q.y);ctx.rotate(q.angle);ctx.globalAlpha=q.alpha;
      ctx.fillStyle=q.color;ctx.fillRect(-q.w/2,-q.h/2,q.w,q.h);ctx.restore();
    });
    f++;
    if(f<230){confettiRAF=requestAnimationFrame(anim);}
    else{canvas.style.display='none';}
  }
  if(confettiRAF)cancelAnimationFrame(confettiRAF);
  anim();
}
function stopConfetti(){
  if(confettiRAF){cancelAnimationFrame(confettiRAF);confettiRAF=null;}
  const c=document.getElementById('confetti-c');if(c)c.style.display='none';
}

/* ===== INIT ===== */
drawWheel(0);
