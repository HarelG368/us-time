    html+=`<span class="cicon">⚡</span><div class="ctext">${card.t}</div>`;
    html+=`<div class="wopts"><div class="wopt">${card.o[0]}</div><div class="vs">— או —</div><div class="wopt">${card.o[1]}</div></div>`;
    html+=`<div class="csub">כל אחד בוחר בנפרד, ואז גלו ודונו</div>`;
  } else if(seg.type==='h'){
    html+=`<span class="cicon">🔥</span><div class="ctext">${card.t}</div>`;
    if(card.s)html+=`<div class="csub">${card.s}</div>`;
    html+=`<div class="hs-timer"><svg width="84" height="84" viewBox="0 0 84 84"><circle cx="42" cy="42" r="36" fill="none" stroke="#f0f0f0" stroke-width="6"/><circle id="tring" cx="42" cy="42" r="36" fill="none" stroke="${seg.bg}" stroke-width="6" stroke-dasharray="226.2" stroke-dashoffset="0" stroke-linecap="round" transform="rotate(-90 42 42)"/></svg><div class="hs-tnum" id="tnum">30</div></div><div class="hs-tsub" id="tsub">לחצו "התחל" להתחיל!</div>`;
  } else {
    html+=`<span class="cicon">${seg.icon}</span><div class="ctext">${card.t}</div>`;
    if(card.s)html+=`<div class="csub">${card.s}</div>`;
  }
  crd.innerHTML=html;
  const db=document.getElementById('doneb');
  if(seg.type==='h'){
    db.textContent='התחל טיימר! ⏱';
    db.onclick=function(){
      if(!hsStarted){
        hsStarted=true;this.textContent='סיימתי! ✓ (+'+curPts+')';
        const sub=document.getElementById('tsub');if(sub)sub.textContent='מהר מהר!';
        startHSTimer();
      } else {
        if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
        resolve(true);
      }
    };
  } else {
    db.textContent='השלמתי ✓ (+'+seg.pts+')';
    db.onclick=()=>resolve(true);
  }
  showSc('s-card');
}

function startHSTimer(){
  let secs=30;
  timerInterval=setInterval(()=>{
    secs--;
    const tn=document.getElementById('tnum');
    const tr=document.getElementById('tring');
    if(tn)tn.textContent=secs;
    if(tr)tr.setAttribute('stroke-dashoffset',226.2*(1-secs/30));
    if(secs<=0){clearInterval(timerInterval);timerInterval=null;resolve(true);}
  },1000);
}

/* ===== SKIP + PENALTY ===== */
function doSkip(){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  skips[turn]++;streak[turn]=0;
  showPenalty();
}

function showPenalty(){
  let idx;let tries=0;
  do{idx=Math.floor(Math.random()*PENALTIES.length);tries++;}
  while(idx===lastPenIdx&&tries<20);
  lastPenIdx=idx;
  document.getElementById('pen-text').textContent=PENALTIES[idx];
  const icons=['🐔','🐓','🐣','🐥'];
  const pi=document.getElementById('pen-icon');
  pi.textContent=icons[Math.floor(Math.random()*icons.length)];
  pi.style.animation='none';requestAnimationFrame(()=>{pi.style.animation='';});
  showSc('s-penalty');
}

function rerollPenalty(){
  let idx;let tries=0;
  do{idx=Math.floor(Math.random()*PENALTIES.length);tries++;}
  while(idx===lastPenIdx&&tries<20);
  lastPenIdx=idx;
  const pt=document.getElementById('pen-text');
  pt.style.opacity='0';
  setTimeout(()=>{pt.textContent=PENALTIES[idx];pt.style.opacity='1';},200);
}

function acceptPenalty(){updateSB();nextTurn();}

/* ===== RESOLVE ===== */
function resolve(done){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  if(done){
    pts[turn]+=curPts;
    streak[turn]++;
    if(streak[turn]>0&&streak[turn]%3===0){
      pts[turn]+=1;
      showToast('🔥 '+p[turn]+' — '+streak[turn]+' ברצף! +1 בונוס!','streak');
    }
    const wrapId=turn===0?'pw1':'pw2';
    animScore(wrapId,curPts);
  }
  updateSB();nextTurn();
}

function nextTurn(){
  round++;
  if(round>=12){showResult();return;}
  turn=1-turn;
  updateSB();updateTrack();
  showSc('s-game');drawWheel(rot);
  document.getElementById('spin-btn').disabled=false;
  document.getElementById('landed').textContent='';
}

